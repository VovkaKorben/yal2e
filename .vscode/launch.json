    "version": "0.2.0",
    "configurations": [
        { "name": "Python Current", "type": "debugpy", "request": "launch", "program": "${file}", "console": "integratedTerminal" },
        { "name": "parse_dump",
            "type": "debugpy",
            "request": "launch",
            "program": "parse_dump.py",
            "console": "integratedTerminal" },
        {
            "type": "node",
            "request": "launch",
            "name": "client2.js",
            "skipFiles": [ "<node_internals>/**" ],
            "program": "${workspaceFolder}/client2.js",
            "runtimeArgs": [
                "--openssl-legacy-provider"
            ]
        }
    ]
}